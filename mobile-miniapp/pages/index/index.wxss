.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #fffaf6 0, #f3f0eb 360rpx, #f5f3ef 100%);
  box-sizing: border-box;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 4rpx 24rpx;
  align-items: flex-start;
}

.eyebrow {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border: 1rpx solid rgba(199, 81, 47, .28);
  border-radius: 999rpx;
  color: #c7512f;
  background: #fff3eb;
  font-size: 22rpx;
  font-weight: 700;
}

.title {
  margin-top: 12rpx;
  color: #2c2520;
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 800;
}

.subtitle {
  max-width: 560rpx;
  margin-top: 10rpx;
  color: #7b6f66;
  font-size: 25rpx;
  line-height: 1.45;
}

.settings-button {
  min-width: 104rpx;
  margin: 0;
  padding: 14rpx 20rpx;
  border: 1rpx solid #ddd5cc;
  border-radius: 16rpx;
  color: #4a3730;
  background: #fffdfb;
  font-size: 24rpx;
}

.status-strip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 72rpx;
  margin-bottom: 18rpx;
  padding: 0 22rpx;
  border: 1rpx solid #e3dad1;
  border-radius: 18rpx;
  background: #fffdfb;
  color: #6d6259;
  font-size: 24rpx;
}

.status-strip.ok {
  border-color: rgba(32, 106, 75, .22);
  color: #206a4b;
  background: #f2fbf6;
}

.status-strip.warn {
  border-color: rgba(181, 106, 23, .30);
  color: #8b4d0e;
  background: #fff7e8;
}

.panel,
.settings-panel {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #ddd5cc;
  border-radius: 22rpx;
  background: rgba(255, 253, 251, .96);
  box-shadow: 0 18rpx 40rpx rgba(91, 61, 42, .08);
}

.composer {
  padding-bottom: 28rpx;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.section-title {
  color: #2c2520;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 760;
}

.helper {
  margin-top: 6rpx;
  color: #82776d;
  font-size: 23rpx;
  line-height: 1.45;
}

.field {
  margin-top: 24rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 10rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #756a61;
  font-size: 24rpx;
  font-weight: 650;
}

.label-row .label {
  margin-bottom: 0;
}

.hint {
  color: #a19890;
  font-size: 22rpx;
}

.input,
.textarea {
  width: 100%;
  border: 1rpx solid #d8d0c8;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  color: #2c2520;
  background: #fffaf6;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 240rpx;
  line-height: 1.55;
}

.counter {
  margin-top: 8rpx;
  text-align: right;
  color: #a19890;
  font-size: 22rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.chip {
  min-height: 60rpx;
  margin: 0;
  padding: 0 20rpx;
  border: 1rpx solid #d8d0c8;
  border-radius: 999rpx;
  color: #4a3730;
  background: #fffdfb;
  font-size: 24rpx;
  line-height: 60rpx;
}

.chip.small {
  min-height: 54rpx;
  padding: 0 18rpx;
  font-size: 23rpx;
  line-height: 54rpx;
}

.chip.active {
  border-color: rgba(199, 81, 47, .42);
  color: #9f3e24;
  background: #fff0e8;
  font-weight: 700;
}

.custom-tag-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 14rpx;
  margin-top: 14rpx;
}

.bind-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 14rpx;
}

.bind-input {
  text-transform: uppercase;
  font-weight: 760;
  letter-spacing: 4rpx;
}

.bind-status {
  margin-top: 14rpx;
  color: #7b6f66;
  font-size: 23rpx;
  line-height: 1.45;
}

.settings-actions {
  grid-template-columns: 1fr 1fr;
}

.dev-field {
  padding-top: 18rpx;
  border-top: 1rpx solid #e1d9d1;
}

.tag-input {
  min-height: 68rpx;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.tag-pill {
  min-height: 48rpx;
  margin: 0;
  padding: 0 16rpx;
  border: 1rpx solid rgba(46, 111, 149, .28);
  border-radius: 999rpx;
  color: #2e6f95;
  background: #eef8fc;
  font-size: 22rpx;
  line-height: 48rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.primary,
.secondary,
.inline-button,
.text-button {
  margin: 0;
  border-radius: 16rpx;
  font-size: 27rpx;
}

.primary {
  min-height: 82rpx;
  border: 1rpx solid #c7512f;
  color: #fff;
  background: #c7512f;
  font-weight: 750;
}

.secondary {
  min-height: 82rpx;
  border: 1rpx solid #d8d0c8;
  color: #4a3730;
  background: #fffdfb;
}

.secondary.compact,
.inline-button {
  min-height: 58rpx;
  padding: 0 18rpx;
  font-size: 23rpx;
}

.inline-button {
  border: 1rpx solid rgba(181, 106, 23, .28);
  color: #8b4d0e;
  background: #fffdfb;
}

.item {
  margin-top: 18rpx;
  padding: 20rpx;
  border: 1rpx solid #e1d9d1;
  border-radius: 18rpx;
  background: #fffaf6;
}

.item-head,
.item-meta {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.item-type {
  color: #4a3730;
  font-size: 23rpx;
  font-weight: 700;
}

.status {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
}

.status.done {
  color: #206a4b;
  background: #eaf7ef;
}

.status.pending {
  color: #2e6f95;
  background: #eef8fc;
}

.status.failed {
  color: #b42318;
  background: #fff0ee;
}

.status.draft {
  color: #82776d;
  background: #f0ece7;
}

.item-content {
  margin-top: 12rpx;
  color: #2c2520;
  font-size: 27rpx;
  line-height: 1.5;
}

.item-meta {
  margin-top: 10rpx;
  color: #938981;
  font-size: 22rpx;
}

.tag-line {
  margin-top: 10rpx;
  color: #2e6f95;
  font-size: 22rpx;
  line-height: 1.45;
}

.item-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.text-button {
  min-height: 50rpx;
  padding: 0 16rpx;
  border: 1rpx solid #d8d0c8;
  color: #4a3730;
  background: #fffdfb;
  font-size: 22rpx;
}

.text-button.danger {
  border-color: rgba(180, 35, 24, .22);
  color: #b42318;
}

.empty {
  margin-top: 18rpx;
  padding: 34rpx 20rpx;
  border: 1rpx dashed #d8d0c8;
  border-radius: 18rpx;
  color: #82776d;
  text-align: center;
  font-size: 24rpx;
}
