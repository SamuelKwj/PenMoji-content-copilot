<view class="page">
  <view class="panel">
    <view class="title">手机灵感入口</view>
    <view class="subtitle">只负责收集和同步，完整生产在电脑端完成。</view>

    <view class="field">
      <text class="label">Cloud Base URL</text>
      <input class="input" value="{{cloudBaseUrl}}" bindinput="onCloudBaseInput" placeholder="https://your-cloud.example.com" />
    </view>

    <view class="field">
      <text class="label">类型</text>
      <picker range="{{types}}" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker">{{types[typeIndex]}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">灵感内容</text>
      <textarea class="textarea" value="{{content}}" bindinput="onContentInput" placeholder="随手记下一个选题、标题、链接说明或评论区观察" />
    </view>

    <view class="field">
      <text class="label">媒体/链接 URL</text>
      <input class="input" value="{{mediaUrl}}" bindinput="onMediaUrlInput" placeholder="可选" />
    </view>

    <view class="field">
      <text class="label">标签，逗号分隔</text>
      <input class="input" value="{{tagsText}}" bindinput="onTagsInput" placeholder="选题,个人IP,待验证" />
    </view>

    <button class="primary" loading="{{submitting}}" bindtap="submitInspiration">提交灵感</button>
    <button class="secondary" loading="{{loadingStatus}}" bindtap="loadStatus">查看同步状态</button>
  </view>

  <view class="panel">
    <view class="title small">最近状态</view>
    <block wx:if="{{items.length}}">
      <view class="item" wx:for="{{items}}" wx:key="id">
        <view class="item-head">
          <text>{{item.type}}</text>
          <text class="status">{{item.sync_status}}</text>
        </view>
        <view class="item-content">{{item.content || item.media_url}}</view>
      </view>
    </block>
    <view wx:else class="empty">还没有同步记录。</view>
  </view>
</view>
